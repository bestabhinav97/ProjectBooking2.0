# Optional — full backend origin (no trailing slash). Use when the API is not
# reachable via the Vite dev proxy (e.g. deployed API).
#
# Leave unset for local dev so the app uses same-origin `/auth/*` (proxied to
# :3000) and session cookies work for PATCH /auth/profile.
#
# VITE_API_URL=https://api.example.com
