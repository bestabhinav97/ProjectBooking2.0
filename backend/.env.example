# MySQL — matches Workbench "Local instance 3306" (Homebrew 8.0.x)
# Host: localhost | Port: 3306 | User: root
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
# Set this to the same password you use in Workbench / mysql -u root -p
DB_PASSWORD=
DB_DB=bookingproject

# Required for login/signup JWT (use any long random string locally)
JWT_SECRET=change-me-to-a-long-random-string-for-local-dev

# Used for password-reset dev links (forgot-password flow). Optional; defaults to http://localhost:5173
FRONTEND_URL=http://localhost:5173
